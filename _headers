# https://developers.cloudflare.com/pages/configuration/headers/
# CF Pages allows one splat (*) per rule. Same-name headers across matching
# rules are comma-joined, so use (! Header) to clear before resetting.

# Hashed assets, filename changes on every build, safe to cache forever
/:slug/assets/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Shared root assets (plugin CSS font paths use Vite's default base: '/')
/assets/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# remoteEntry.js is unhashed, clear the immutable above then set no-store
/:slug/assets/remoteEntry.js
  ! Cache-Control
  Cache-Control: no-store, must-revalidate

# Registry manifest, always fresh
/manifest.json
  Access-Control-Allow-Origin: *
  Cache-Control: no-store, must-revalidate
  Content-Type: application/json; charset=utf-8
  X-Content-Type-Options: nosniff

# Locale files, short cache since translations update occasionally
/:slug/locale/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff
